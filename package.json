{
    "name": "google-sheets-summarizer",
    "version": "1.0.0",
    "description": "Summarizes URLs from a Google Sheet using Gemini.",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "pipeline": "node runLeadPipeline.js",
        "pipeline:food": "node runLeadPipeline.js --industry 'Food'",
        "pipeline:spain": "node runLeadPipeline.js --country 'Spain'",
        "pipeline:dry": "node runLeadPipeline.js --dry-run",
        "apollo": "node apolloEnricher.js",
        "qualify-leads": "node leadQualifier.js",
        "verify-emails": "node millionVerifier.js",
        "import-historical": "node importHistoricalData.js",
        "lead-stats": "node leadStats.js",
        "news-fetch": "node eventRegistryNewsFetcher.js",
        "news-extract": "node newsLeadExtractor.js",
        "news-emails": "node newsEmailGenerator.js",
        "news-leads": "node newsBasedLeadGeneration.js",
        "outreach": "node seoOutreachLeadGeneration.js",
        "apify-contacts": "node apifyContactRunner.js",
        "supplier-pipeline": "node supplierOutreachPipeline.js",
        "supplier-pipeline:dry": "node supplierOutreachPipeline.js --dry-run",
        "supplier-add-product": "node productCatalogManager.js add",
        "supplier-list-products": "node productCatalogManager.js list",
        "supplier-qualify": "node supplierQualifier.js",
        "supplier-emails": "node supplierEmailGenerator.js",
        "supplier-outreach": "node automatedEmailOutreach.js",
        "supplier-status": "node automatedEmailOutreach.js status",
        "setup-email": "node setupEmailInfrastructure.js",
        "supplier-finder": "node simple-supplier-finder.js",
        "supplier-finder-manual": "node supplier-finder-manual.js",
        "setup-supplier": "node setup-supplier-config.js"
    },
    "dependencies": {
        "@google/generative-ai": "^0.14.1",
        "apify": "^3.4.5",
        "axios": "^1.13.2",
        "cheerio": "^1.1.2",
        "csv-parser": "^3.0.0",
        "csv-writer": "^1.6.0",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
        "googleapis": "^140.0.1",
        "lucide-react": "^0.539.0",
        "nodemailer": "^6.9.8",
        "pdf-lib": "^1.17.1",
        "sharp": "^0.34.3"
    }
}
